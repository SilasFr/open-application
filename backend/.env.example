# Copy to .env and fill in. Never commit .env.

# App
APP_NAME="Open Application"
ENVIRONMENT="development"
# Comma-separated list of allowed CORS origins (frontend URLs)
CORS_ORIGINS="http://localhost:3000"

# Supabase (Project Settings -> API)
SUPABASE_URL=""
# Service role key is used server-side only. Keep it secret.
SUPABASE_SERVICE_KEY=""
# Access-token verification:
#   - Asymmetric-key projects (default): leave SUPABASE_JWT_SECRET empty; tokens
#     are verified against SUPABASE_URL's JWKS endpoint.
#   - Legacy HS256 projects: set the JWT secret from Project Settings -> API.
SUPABASE_JWT_SECRET=""

# AI (CV tailoring) — "gemini" (free tier, default), "anthropic", or
# "openai_compatible" (self-hosted / open-model via the OpenAI wire format).
AI_PROVIDER="gemini"
# Free API key from https://aistudio.google.com/apikey (no billing required)
GEMINI_API_KEY=""
# Only needed if AI_PROVIDER="anthropic"
ANTHROPIC_API_KEY=""
# Only needed if AI_PROVIDER="openai_compatible". Works with a local Ollama /
# llama.cpp server or a hosted open-model API (Groq, Together, DeepInfra, …).
#   Local Ollama:  AI_BASE_URL="http://localhost:11434/v1"  AI_API_KEY=""
#                  AI_MODEL="qwen2.5:7b-instruct"
#   Groq (hosted): AI_BASE_URL="https://api.groq.com/openai/v1"  AI_API_KEY="gsk_..."
#                  AI_MODEL="llama-3.1-8b-instant" | llama-3.3-70b-versatile 
AI_BASE_URL=""
AI_API_KEY=""
# Default model for CV tailoring. Override per environment/provider as needed.
AI_MODEL="gemini-2.0-flash"
AI_MAX_TOKENS="4096"

# BYOK: users can bring their own AI provider key instead of using the shared
# key above. Required only to enable that feature — generate with:
#   python -c "import base64,os; print(base64.b64encode(os.urandom(32)).decode())"
# Leave empty to disable BYOK; users without a saved key are unaffected either way.
BYOK_ENCRYPTION_KEY=""