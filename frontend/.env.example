# Supabase project credentials — copy to .env.local and fill in your values.
# Find these in the Supabase Dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# ── OAuth + password reset setup ─────────────────────────────────────────────
# 1. Enable Google and LinkedIn providers in Supabase Dashboard →
#    Authentication → Providers.
# 2. Add the following URL to the "Redirect URLs" allowlist in
#    Supabase Dashboard → Authentication → URL Configuration. This one entry
#    covers BOTH OAuth sign-in and password reset — both flows redirect
#    through /auth/callback. A redirect_to that isn't in this allowlist is
#    silently downgraded to the bare site URL, which breaks both flows.
#      <your-site-url>/auth/callback
#    e.g. http://localhost:3000/auth/callback (local dev)
#         https://your-app.com/auth/callback  (production)
